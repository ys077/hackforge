# ML Service Environment Variables

# App settings
APP_NAME=HackForge ML Service
APP_VERSION=2.0.0
DEBUG=true
ENVIRONMENT=development

# Server settings
HOST=0.0.0.0
PORT=8001

# Redis settings
REDIS_URL=redis://localhost:6379/1

# NLP Model settings
MODEL_CACHE_DIR=./models
SENTENCE_TRANSFORMER_MODEL=all-MiniLM-L6-v2

# OCR settings (optional — set path to tesseract binary)
# TESSERACT_PATH=/usr/bin/tesseract

# ------- Model 1: Scheme Recommender -------
SCHEME_PORTAL_URL=https://www.india.gov.in/my-government/schemes
SCHEME_SCRAPE_INTERVAL_HOURS=24
SCHEME_CACHE_TTL_SECONDS=86400
SCHEME_TOP_N=5

# ------- Model 2: Resume Builder -------
LINKEDIN_SCRAPE_ENABLED=true
RESUME_PDF_OUTPUT_DIR=./output/resumes
RESUME_MAX_SKILLS=20
RESUME_ATS_OPTIMIZATION=true

# ------- Model 3: Document Verification -------
DOC_VERIFY_TAMPERING_THRESHOLD=0.30
DOC_VERIFY_MIN_CONFIDENCE=0.60
TRUST_SCORE_DOC_WEIGHT=0.35
TRUST_SCORE_CONSISTENCY_WEIGHT=0.25
TRUST_SCORE_AUTHENTICITY_WEIGHT=0.25
TRUST_SCORE_EMPLOYMENT_WEIGHT=0.15

# ------- Model 4: Job Matcher -------
JOB_PORTAL_BASE_URL=https://in.indeed.com
JOB_SCRAPE_INTERVAL_HOURS=6
JOB_CACHE_TTL_SECONDS=21600
JOB_TOP_N=10

# Matching weights
SKILLS_WEIGHT=0.40
EDUCATION_WEIGHT=0.25
EXPERIENCE_WEIGHT=0.20
LOCATION_WEIGHT=0.15
