# Server Configuration
NODE_ENV=development
PORT=3000
API_VERSION=v1

# MongoDB Configuration
# For local development:
# MONGO_URL=mongodb://localhost:27017/hackforge
# For Railway deployment:
MONGO_URL=mongodb://mongo:CarUDyYDWJSACDuDItvguDVursVvsGZL@switchyard.proxy.rlwy.net:17236

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# JWT Configuration
JWT_SECRET=your_super_secure_jwt_secret_key_here
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your_refresh_token_secret_key
JWT_REFRESH_EXPIRES_IN=30d

# OTP Configuration
OTP_EXPIRY_MINUTES=5
OTP_LENGTH=6

# File Upload Configuration
MAX_FILE_SIZE=10485760
UPLOAD_DIR=uploads
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/jpg,application/pdf

# MapTiler API Configuration
MAPTILER_API_KEY=1ePgGuUyZhKj3gBeAZ6O
MAPTILER_BASE_URL=https://api.maptiler.com

# ML Service Configuration
ML_SERVICE_URL=http://localhost:8000
ML_SERVICE_TIMEOUT=30000

# SMS Provider Configuration (Twilio/MSG91)
SMS_PROVIDER=twilio
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# Email Configuration (Optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
EMAIL_FROM=noreply@hackforge.com

# Socket.IO Configuration
SOCKET_CORS_ORIGIN=http://localhost:3001

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Logging
LOG_LEVEL=info
LOG_FILE=logs/app.log

# Encryption
ENCRYPTION_KEY=your_32_character_encryption_key

# External APIs
AADHAAR_VERIFICATION_URL=
PAN_VERIFICATION_URL=

# Railway Deployment
RAILWAY_ENVIRONMENT=production
